<Window x:Class="TamilDesktopWidget.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
       
        Width="1000"
        Height="700"
        WindowStartupLocation="CenterOwner"
       ResizeMode="CanResizeWithGrip"
        Background="#F3F3F3" Icon="/AhaConvert_img.icons8.ico">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT MENU -->

        <Border Grid.Column="0"
                Background="White">

            <StackPanel Margin="20">

                <TextBlock Text="Settings"
                           FontSize="30"
                           FontWeight="Bold"
                           Margin="10,20"/>

                <Button x:Name="AppearanceButton"
                        Content="🎨 Appearance"
                        Height="48"
                        Margin="0,10"
                        Click="AppearanceButton_Click"/>

                <Button x:Name="WidgetButton"
                        Content="⚙ Widget"
                        Height="48"
                        Margin="0,10"
                        Click="WidgetButton_Click"/>

                <Button x:Name="AboutButton"
                        Content="ℹ About"
                        Height="48"
                        Margin="0,10"
                        Click="AboutButton_Click"/>

            </StackPanel>

        </Border>

        <!-- RIGHT CONTENT -->

        <Grid Grid.Column="1">

            <!-- Appearance Page -->

            <ScrollViewer x:Name="AppearancePage">

                <StackPanel Margin="35">

                    <TextBlock Text="Appearance"
           FontSize="32"
           FontWeight="SemiBold"
           Margin="0,0,0,25"/>

<!-- Background Style -->

<TextBlock Text="Background Style"
           FontSize="18"
           FontWeight="SemiBold"
           Margin="0,0,0,15"/>

<UniformGrid Columns="3"
             Margin="0,0,0,25">

    <!-- Solid -->

    <Border x:Name="SolidCard"
            Margin="8"
            Padding="15"
            CornerRadius="12"
            BorderBrush="#C7C7C7"
            BorderThickness="2"
            Background="White"
            Cursor="Hand"
            MouseLeftButtonDown="SolidCard_MouseLeftButtonDown">

        <StackPanel>

            <TextBlock Text="🎨"
                       FontSize="34"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Solid Color"
                       Margin="0,10,0,0"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>

        </StackPanel>

    </Border>

    <!-- Transparent -->

    <Border x:Name="TransparentCard"
            Margin="8"
            Padding="15"
            CornerRadius="12"
            BorderBrush="#C7C7C7"
            BorderThickness="2"
            Background="White"
            Cursor="Hand"
            MouseLeftButtonDown="TransparentCard_MouseLeftButtonDown">

        <StackPanel>

            <TextBlock Text="🌫"
                       FontSize="34"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Transparent"
                       Margin="0,10,0,0"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>

        </StackPanel>

    </Border>

    <!-- Image -->

       <Border x:Name="ImageCard"
        Margin="8"
        Padding="15"
        CornerRadius="12"
        BorderBrush="#C7C7C7"
        BorderThickness="2"
        Background="White"
        Cursor="Hand"
        MouseLeftButtonDown="ImageCard_MouseLeftButtonDown">

                            <StackPanel>

                                <TextBlock Text="🖼"
               FontSize="34"
               HorizontalAlignment="Center"/>

                                <TextBlock Text="Background Image"
               Margin="0,10,0,15"
               FontWeight="SemiBold"
               HorizontalAlignment="Center"/>

                                <StackPanel x:Name="ImagePanel">

                                    <Button x:Name="ChooseImageButton"
                Content="Choose Image..."
                Width="150"
                Height="35"
                HorizontalAlignment="Center"
                Click="ChooseImageButton_Click"/>

                                    <TextBlock x:Name="ImagePathText"
                   Margin="0,10,0,0"
                   FontSize="11"
                   Foreground="Gray"
                   TextWrapping="Wrap"
                   TextAlignment="Center"/>

                                </StackPanel>

                            </StackPanel>

                        </Border>

         </UniformGrid>

<!-- Background Color -->

                    <StackPanel x:Name="BackgroundColorPanel">

                        <TextBlock Text="Background Color"
               FontSize="18"
               FontWeight="SemiBold"/>

                        <Border x:Name="BackgroundColorBox"
            Width="60"
            Height="60"
            Margin="0,15,0,25"
            CornerRadius="8"
            Background="#DD1F1F1F"
            BorderBrush="#808080"
            BorderThickness="1"
            Cursor="Hand"
            MouseLeftButtonDown="BackgroundColorBox_MouseLeftButtonDown"/>

                    </StackPanel>
                    <!-- Opacity -->

<TextBlock Text="Opacity"
           FontSize="18"
           FontWeight="SemiBold"/>

                    <Slider x:Name="OpacitySlider"
        Minimum="20"
        Maximum="100"
        Value="85"
        ValueChanged="OpacitySlider_ValueChanged"/>

                    <!-- Font -->

<TextBlock Text="Font"
           FontSize="18"
           FontWeight="SemiBold"/>

<ComboBox x:Name="FontComboBox"
          Margin="0,15,0,25"
          Height="35">

    <ComboBoxItem>Segoe UI</ComboBoxItem>
    <ComboBoxItem>Arial</ComboBoxItem>
    <ComboBoxItem>Calibri</ComboBoxItem>
    <ComboBoxItem>Tahoma</ComboBoxItem>
    <ComboBoxItem>Nirmala UI</ComboBoxItem>

</ComboBox>

<!-- Font Size -->

<TextBlock Text="Font Size"
           FontSize="18"
           FontWeight="SemiBold"/>

<ComboBox x:Name="FontSizeComboBox"
          Margin="0,15,0,25"
          Height="35">

  <ComboBoxItem>32</ComboBoxItem>
 <ComboBoxItem>40</ComboBoxItem>
  <ComboBoxItem>48</ComboBoxItem>
 <ComboBoxItem IsSelected="True">60</ComboBoxItem>
<ComboBoxItem>72</ComboBoxItem>

   </ComboBox>

                    <!-- English Color -->

<TextBlock Text="English Text Color"
           FontSize="18"
           FontWeight="SemiBold"/>

                    <Border x:Name="EnglishColorBox"
        Width="60"
        Height="60"
        Margin="0,15,0,25"
        Background="White"
        BorderBrush="Gray"
        BorderThickness="1"
        CornerRadius="8"
        Cursor="Hand"
        MouseLeftButtonDown="EnglishColorBox_MouseLeftButtonDown"/>

                    <!-- Tamil Color -->

<TextBlock Text="Tamil Text Color"
           FontSize="18"
           FontWeight="SemiBold"/>

                    <Border x:Name="TamilColorBox"
        Width="60"
        Height="60"
        Margin="0,15,0,25"
        Background="#FFD08C"
        BorderBrush="Gray"
        BorderThickness="1"
        CornerRadius="8"
        Cursor="Hand"
        MouseLeftButtonDown="TamilColorBox_MouseLeftButtonDown"/>

                


                    <!-- Bottom Buttons -->

<Border BorderBrush="#DDDDDD"
        BorderThickness="0,1,0,0"
        Margin="0,20,0,0"
        Padding="0,20,0,0">

    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right">

                            <Button x:Name="CancelButton"
        Content="Cancel"
        Width="100"
        Height="38"
        Margin="5"
        Click="CancelButton_Click"/>

                            <Button x:Name="ApplyButton"
                Content="Apply"
                Width="100"
                Height="38"
                Margin="5"
                Click="ApplyButton_Click"/>

        <Button x:Name="SaveButton"
                Content="Save"
                Width="100"
                Height="38"
                Margin="5"
                Click="SaveButton_Click"/>

    </StackPanel>

</Border>

                </StackPanel>

            </ScrollViewer>

            <!-- Widget Page -->
            <Grid x:Name="WidgetPage"
      Visibility="Collapsed">

                <StackPanel Margin="35">

                    <TextBlock Text="Widget"
                   FontSize="32"
                   FontWeight="SemiBold"
                   Margin="0,0,0,30"/>

                    <CheckBox x:Name="AlwaysOnTopCheckBox"
                  Content="Always On Top"
                  FontSize="18"
                  Margin="0,10"
                  Checked="AlwaysOnTopCheckBox_Checked"
                  Unchecked="AlwaysOnTopCheckBox_Checked"/>

                    <CheckBox x:Name="StartupCheckBox"
                  Content="Start with Windows"
                  FontSize="18"
                  Margin="0,10"
                  Checked="StartupCheckBox_Checked"
                  Unchecked="StartupCheckBox_Checked"/>

                    <TextBlock Text="Corner Radius"
           FontSize="18"
           FontWeight="SemiBold"
           Margin="0,20,0,10"/>

                    <Slider x:Name="CornerRadiusSlider"
        Minimum="0"
        Maximum="40"
        ValueChanged="CornerRadiusSlider_ValueChanged"/>

                    <TextBlock Text="Window Opacity"
           FontSize="18"
           FontWeight="SemiBold"
           Margin="0,20,0,10"/>

                    <Slider x:Name="WindowOpacitySlider"
        Minimum="20"
        Maximum="100"
        ValueChanged="WindowOpacitySlider_ValueChanged"/>





                </StackPanel>

            </Grid>
            <!-- About Page -->

            <!-- About Page -->

            <Grid x:Name="AboutPage"
      Visibility="Collapsed">

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel Margin="35">

                        <TextBlock Text="About"
                       FontSize="32"
                       FontWeight="Bold"
                       Margin="0,0,0,25"/>

                        <!-- App Name -->

                        <TextBlock Text="🕒 Tamil Desktop Widget"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

                        <TextBlock Text="Version 1.0.0"
                       FontSize="16"
                       Foreground="Gray"
                       Margin="0,8,0,30"
                       HorizontalAlignment="Center"/>

                        <!-- Description -->

                        <TextBlock Text="Tamil Desktop Widget is a lightweight and customizable Windows desktop widget that displays the current time, English calendar, and Tamil calendar directly on your desktop."
                       FontSize="16"
                       TextWrapping="Wrap"/>

                        <TextBlock Text="The widget provides a modern interface with multiple customization options, allowing users to personalize its appearance according to their preferences."
                       Margin="0,15,0,30"
                       FontSize="16"
                       TextWrapping="Wrap"/>

                        <!-- Features -->

                        <TextBlock Text="Features"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

                        <TextBlock Text="✔ Live Digital Clock (12-Hour Format)"
                       Margin="10,4"/>

                        <TextBlock Text="✔ English Day &amp; Date"
                       Margin="10,4"/>

                        <TextBlock Text="✔ Tamil Calendar"
                       Margin="10,4"/>

                        <TextBlock Text="✔ Tamil Week Day"
                       Margin="10,4"/>

                        <TextBlock Text="✔ Solid Color Background"
                       Margin="10,4"/>

                        <TextBlock Text="✔ Transparent Background"
                       Margin="10,4"/>

                        <TextBlock Text="✔ Custom Background Image"
                       Margin="10,4"/>

                        <TextBlock Text="✔ Background Color Picker"
                       Margin="10,4"/>

                        <TextBlock Text="✔ English Text Color Picker"
                       Margin="10,4"/>

                        <TextBlock Text="✔ Tamil Text Color Picker"
                       Margin="10,4"/>

                        <TextBlock Text="✔ Adjustable Background Opacity"
                       Margin="10,4"/>

                        <TextBlock Text="✔ Adjustable Window Opacity"
                       Margin="10,4"/>

                        <TextBlock Text="✔ Font Family Selection"
                       Margin="10,4"/>

                        <TextBlock Text="✔ Font Size Selection"
                       Margin="10,4"/>

                        <TextBlock Text="✔ Rounded Corner Customization"
                       Margin="10,4"/>

                        <TextBlock Text="✔ Always On Top"
                       Margin="10,4"/>

                        <TextBlock Text="✔ Start with Windows"
                       Margin="10,4"/>

                        <TextBlock Text="✔ Movable Widget"
                       Margin="10,4"/>

                        <TextBlock Text="✔ Resizable Widget"
                       Margin="10,4"/>

                        <TextBlock Text="✔ Lock / Unlock Widget"
                       Margin="10,4"/>

                        <TextBlock Text="✔ System Tray Support"
                       Margin="10,4"/>

                        <TextBlock Text="✔ Automatic Settings Save"
                       Margin="10,4"/>

                        <Separator Margin="0,30"/>

                        <!-- Technologies -->

                        <TextBlock Text="Technologies Used"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

                        <TextBlock Text="• C#"
                       Margin="10,4"/>

                        <TextBlock Text="• .NET 8"
                       Margin="10,4"/>

                        <TextBlock Text="• Windows Presentation Foundation (WPF)"
                       Margin="10,4"/>

                        <TextBlock Text="• XAML"
                       Margin="10,4"/>

                        <TextBlock Text="• JSON Settings Storage"
                       Margin="10,4"/>

                        <TextBlock Text="• Microsoft.Win32"
                       Margin="10,4"/>

                        <TextBlock Text="• Windows Forms Color Dialog"
                       Margin="10,4"/>

                        <TextBlock Text="• DispatcherTimer"
                       Margin="10,4"/>

                        <TextBlock Text="• Windows Registry Startup"
                       Margin="10,4"/>

                        <Separator Margin="0,30"/>

                        <!-- Developer -->

                        <TextBlock Text="Developer"
           FontSize="22"
           FontWeight="Bold"
           Margin="0,0,0,15"/>

                        <StackPanel Orientation="Horizontal"
            Margin="0,0,0,15">

                            <!-- Company Logo -->
                            <Image Source="Assets/BilvaLogo.png"
       Width="70"
       Height="70"/>
           

                            <StackPanel>

                                <TextBlock Text="Tarunika K"
                   FontSize="18"
                   FontWeight="Bold"/>

                                <TextBlock Text="Founder &amp; Software Developer"
                   Margin="0,5,0,0"/>

                                <TextBlock Text="Bilva Software"
                   FontWeight="SemiBold"
                   Foreground="#007ACC"/>

                                <TextBlock>
    <Hyperlink Click="Email_Click">
        bilvasoftware@gmail.com
    </Hyperlink>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap">
    <Hyperlink Click="LinkedIn_Click">
        LinkedIn Profile
    </Hyperlink>
                                </TextBlock>

                            </StackPanel>

                        </StackPanel>

                        <Separator Margin="0,30"/>

                        <TextBlock Text="Tamil Desktop Widget"
           FontSize="18"
           FontWeight="Bold"
           HorizontalAlignment="Center"/>

                        <TextBlock Text="Version 1.0.0"
           HorizontalAlignment="Center"/>

                        <TextBlock Text="© 2026 Bilva Software. All Rights Reserved."
           HorizontalAlignment="Center"
           Margin="0,15,0,10"
           Foreground="Gray"/>
                    </StackPanel>

                </ScrollViewer>

            </Grid>


        </Grid>

    </Grid>

</Window>